# ============================================================
# 365 Techies — .htaccess (Apache). Place in the web root.
# Handles: HTTPS + non-www canonical, custom 404, 301 redirects
# from the old WordPress URLs, gzip compression and caching.
# ============================================================

Options -Indexes
DirectoryIndex index.html

RewriteEngine On

# --- Force non-www, then HTTPS (loop-safe behind SiteGround/Cloudflare) ---
RewriteCond %{HTTP_HOST} ^www\. [NC]
RewriteRule ^ https://365techies.co.uk%{REQUEST_URI} [L,R=301]
RewriteCond %{HTTPS} off
RewriteCond %{HTTP:X-Forwarded-Proto} !https [NC]
RewriteRule ^ https://365techies.co.uk%{REQUEST_URI} [L,R=301]

# --- 410 Gone: dead WordPress / WooCommerce / BuddyPress system pages ---
RewriteRule ^(members|members-2|activity|activity-2|groups|forums|register|register-2|activate|profile|moderation|messages|notifications|videos|documents|photos|password-reset|password-recover|external-link|sidebar|gutenberg|remote-jobs|365live|my-account|my-account-2|cart|checkout|checkout-2|shop-2)/?$ - [G]
RewriteRule ^shop/?$ /dell-hardware/ [R=301,L]

# ============================================================
# 301 REDIRECTS — old WordPress pages -> new pages
# ============================================================

# --- Company / core ---
RewriteRule ^about-us/?$                                      /about/ [R=301,L]
RewriteRule ^terms-of-service/?$                              /terms/ [R=301,L]
RewriteRule ^privacy/?$                                       /privacy-policy/ [R=301,L]
RewriteRule ^f-?a-?q/?$                                       /faqs/ [R=301,L]
RewriteRule ^(prices|products)/?$                             /pricing/ [R=301,L]
RewriteRule ^services-2/?$                                    /services/ [R=301,L]
RewriteRule ^book-now/?$                                      /book-service/ [R=301,L]

# --- Home / support ---
RewriteRule ^(support|home-computer-support|home-computer-servicing-and-support)/?$ /home-it-support-subscriptions/ [R=301,L]
RewriteRule ^computer-support-bournemouth/?$                  /it-support-bournemouth/ [R=301,L]
RewriteRule ^it-support-near-me-computer-repair-support-and-servicing/?$ /services/ [R=301,L]

# --- Repairs ---
RewriteRule ^(computer-repair|repairs|computer-help-near-me|computer-repair-near-me-service-support)/?$ /computer-repairs/ [R=301,L]

# --- Specific service pages ---
RewriteRule ^(windows-11-upgrades-dell-bournemouth|windows-11-upgrade-dell|how-to-upgrade-to-windows-11-without-waiting-in-line)/?$ /windows-11-support/ [R=301,L]
RewriteRule ^(email-hosting|website-email-hosting)/?$        /web-design-hosting/ [R=301,L]
RewriteRule ^microsoft-office-support/?$                      /microsoft-365-support/ [R=301,L]

# --- Town pages: old "computer-repair-near-me-service-support-TOWN" -> new computer-repair-TOWN ---
RewriteRule ^computer-repair-near-me-service-support-(beaminster|blandford-forum|boscombe|bournemouth|bridport|canford-heath|christchurch|corfe-mullen|dorchester|ferndown|gillingham|lyme-regis|poole|portland|shaftesbury|sherborne|st-ives|sturminster-newton|swanage|upton|verwood|wareham|west-moors|west-parley|weymouth|wool|wyke-regis)/?$ /computer-repair-$1/ [R=301,L]
RewriteRule ^computer-repair-near-me-service-support-wimborne-minster/?$ /computer-repair-wimborne/ [R=301,L]
# Any other old town / doorway page (villages without a page + non-Dorset junk) -> Areas Covered
RewriteRule ^computer-repair-near-me                          /areas-covered/ [R=301,L]

# --- Blog / articles -> nearest new page ---
RewriteRule ^blog/?$                                          /it-advice/ [R=301,L]
RewriteRule ^top-20-advantages-of-remote-computer-support/?$ /remote-it-support/ [R=301,L]
RewriteRule ^avoid-temptation-to-turn-off-your-wifi-at-night-to-try-and-save-on-energy-bills/?$ /wifi-support/ [R=301,L]
RewriteRule ^impacts-of-remote-work/?$                        /it-support-for-home-workers/ [R=301,L]
RewriteRule ^stolen-laptop-recovered/?$                       /lost-or-stolen-laptop-what-to-do/ [R=301,L]
RewriteRule ^(7-reasons-to-buy-a-refurbished-laptop|refurbishing-a-laptop)/?$ /are-refurbished-laptops-any-good/ [R=301,L]
RewriteRule ^ten-side-hustle-ideas-to-help-you-make-some-extra-cash/?$ /it-advice/ [R=301,L]

# --- Old WordPress sitemaps -> new sitemap ---
RewriteRule ^(sitemap_index\.xml|page-sitemap\.xml|post-sitemap\.xml|wp-sitemap\.xml)$ /sitemap.xml [R=301,L]

# ============================================================
# Custom 404
# ============================================================
ErrorDocument 404 /404.html

# ============================================================
# Don't serve the FTP deploy state file or any stray source files
# ============================================================
<FilesMatch "(\.ftp-deploy-sync-state\.json|\.py|\.toml|\.ya?ml)$">
  Require all denied
</FilesMatch>

# ============================================================
# Performance: compression (Brotli preferred, gzip fallback)
# ============================================================
<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS text/html text/css text/plain text/xml application/javascript application/json image/svg+xml
</IfModule>
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/plain text/xml application/javascript application/json image/svg+xml
</IfModule>

# ============================================================
# Performance: browser caching
# ============================================================
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>
<IfModule mod_headers.c>
  # Versioned assets (?v=) are safe to cache forever
  <FilesMatch "\.(css|js|svg|jpe?g|png|ico|webp|woff2)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # HTML must always revalidate so updates show immediately
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache"
  </FilesMatch>
</IfModule>
